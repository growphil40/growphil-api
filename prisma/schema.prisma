datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum AgencyPlan {
  free_trial
  starter
  pro
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum SubscriptionPlan {
  FREE_TRIAL
  STARTER
  PROFESSIONAL
}

enum UserRole {
  super_admin
  agency_admin
  client_owner
  sales_manager
  sales_executive
}

enum LeadStage {
  NEW
  CONTACTED
  FOLLOW_UP
  QUALIFIED
  NEGOTIATION
  WON
  LOST
  BOOKED
  NO_NEED
  WRONG_LEAD
}

enum FollowUpStatus {
  pending
  done
  missed
}

model Agency {
  id                         String             @id @default(uuid()) @db.Uuid
  name                       String             @db.VarChar(255)
  email                      String             @unique @db.VarChar(255)
  plan                       AgencyPlan
  trialEndsAt                DateTime?          @map("trial_ends_at")
  isActive                   Boolean            @default(true) @map("is_active")
  emailVerified              Boolean            @default(false) @map("email_verified")
  emailVerifiedAt            DateTime?          @map("email_verified_at")
  verificationToken          String?            @map("verification_token")
  verificationTokenExpiresAt DateTime?          @map("verification_token_expires_at")
  subscriptionStatus         SubscriptionStatus @default(TRIAL) @map("subscription_status")
  subscriptionPlan           SubscriptionPlan   @default(FREE_TRIAL) @map("subscription_plan")
  trialStartDate             DateTime?          @map("trial_start_date")
  trialEndDate               DateTime?          @map("trial_end_date")
  subscriptionStartDate      DateTime?          @map("subscription_start_date")
  subscriptionEndDate        DateTime?          @map("subscription_end_date")
  isTrialExpired             Boolean            @default(false) @map("is_trial_expired")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")

  clients       Client[]
  users         User[]
  leads         Lead[]
  followUps     FollowUp[]
  sales         Sale[]
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]

  @@map("agencies")
}

model Client {
  id               String        @id @default(uuid()) @db.Uuid
  agencyId         String        @map("agency_id") @db.Uuid
  businessName     String        @map("business_name") @db.VarChar(255)
  email            String        @unique @db.VarChar(255)
  metaAccessToken  String?       @map("meta_access_token") @db.Text
  metaAdAccountId  String?       @map("meta_ad_account_id") @db.VarChar(100)
  metaPageId       String?       @map("meta_page_id") @db.VarChar(100)
  metaFormId       String?       @map("meta_form_id") @db.VarChar(100)
  metaBusinessId   String?       @map("meta_business_id") @db.VarChar(100)
  metaConnectedAt  DateTime?     @map("meta_connected_at")
  metaLastSyncAt   DateTime?     @map("meta_last_sync_at")
  metaTokenStatus  String?       @default("PENDING") @map("meta_token_status") @db.VarChar(20)
  tokenExpiresAt   DateTime?     @map("token_expires_at")
  metaAdSpend      Decimal       @default(0.00) @map("meta_ad_spend") @db.Decimal(12, 2)
  metaPageName         String?       @map("meta_page_name") @db.VarChar(255)
  metaPageAccessToken  String?       @map("meta_page_access_token") @db.Text
  metaAdAccountName    String?       @map("meta_ad_account_name") @db.VarChar(255)
  metaLastError          String?       @map("meta_last_error") @db.Text
  metaPermissionSnapshot Json?         @map("meta_permission_snapshot")
  isDeleted        Boolean       @default(false) @map("is_deleted")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  agency        Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  users         User[]
  leads         Lead[]
  followUps     FollowUp[]
  sales         Sale[]
  activityLogs  ActivityLog[]
  refreshTokens RefreshToken[]
  googleConnections          GoogleConnection[]
  spreadsheetConnections      SpreadsheetConnection[]
  spreadsheetColumnMappings   SpreadsheetColumnMapping[]
  spreadsheetImportHistories  SpreadsheetImportHistory[]
  workflows                  Workflow[]
  conversations              Conversation[]
  tasks                      Task[]
  tags                       Tag[]
  notifications              Notification[]

  @@map("clients")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  agencyId     String?       @map("agency_id") @db.Uuid
  clientId     String?       @map("client_id") @db.Uuid
  role         UserRole
  email        String        @unique @db.VarChar(255)
  passwordHash String        @map("password_hash") @db.Text
  passwordResetToken          String?   @map("password_reset_token") @db.VarChar(255)
  passwordResetTokenExpiresAt DateTime? @map("password_reset_token_expires_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  agency       Agency?       @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leads        Lead[]        @relation("AssignedLeads")
  activityLogs ActivityLog[]
  refreshTokens RefreshToken[]
  tasks         Task[]
  notifications Notification[]

  @@map("users")
}

model Lead {
  id           String        @id @default(uuid()) @db.Uuid
  clientId     String        @map("client_id") @db.Uuid
  agencyId     String        @map("agency_id") @db.Uuid
  metaLeadId   String?       @unique @map("meta_lead_id") @db.VarChar(100)
  name         String        @db.VarChar(255)
  phone        String?       @db.VarChar(30)
  email        String?       @db.VarChar(255)
  stage        LeadStage     @default(NEW)
  source       String?       @db.VarChar(255)
  city         String?       @db.VarChar(255)
  leadSource   String?       @map("lead_source") @db.VarChar(100)
  status       String?       @default("ACTIVE") @db.VarChar(50)
  createdBy    String?       @default("SYSTEM") @map("created_by") @db.VarChar(50)
  assignedTo   String?       @map("assigned_to") @db.Uuid
  campaignName  String?       @map("campaign_name") @db.VarChar(255)
  pageName      String?       @map("page_name") @db.VarChar(255)
  adAccountName String?       @map("ad_account_name") @db.VarChar(255)
  metaCreatedAt DateTime?     @map("meta_created_at")
  customFields Json?         @map("custom_fields")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  assignedUser User?         @relation("AssignedLeads", fields: [assignedTo], references: [id], onDelete: SetNull)
  followUps    FollowUp[]
  sales        Sale[]
  activityLogs ActivityLog[]
  syncHistories LeadSyncHistory[]
  score        LeadScore?
  tasks         Task[]
  leadTags      LeadTag[]
  conversations Conversation[]

  @@index([clientId, stage], name: "idx_leads_client_stage")
  @@map("leads")
}

model FollowUp {
  id          String         @id @default(uuid()) @db.Uuid
  leadId      String         @map("lead_id") @db.Uuid
  clientId    String         @map("client_id") @db.Uuid
  agencyId    String         @map("agency_id") @db.Uuid
  scheduledAt DateTime       @map("scheduled_at")
  note        String?        @db.Text
  status      FollowUpStatus @default(pending)
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  lead        Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agency      Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("follow_ups")
}

model Sale {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  agencyId  String   @map("agency_id") @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("INR") @db.VarChar(3)
  closedAt  DateTime @map("closed_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("sales")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  agencyId  String   @map("agency_id") @db.Uuid
  action    String   @db.VarChar(255)
  oldValue  String?  @map("old_value") @db.Text
  newValue  String?  @map("new_value") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("activity_log")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  clientId  String?  @map("client_id") @db.Uuid
  agencyId  String?  @map("agency_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.Text
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agency    Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model GoogleConnection {
  id           String   @id @default(uuid()) @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  googleEmail  String   @map("google_email") @db.VarChar(255)
  accessToken  String   @map("access_token") @db.Text
  refreshToken String   @map("refresh_token") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("google_connections")
}

model SpreadsheetConnection {
  id              String   @id @default(uuid()) @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  sheetUrl        String?  @map("sheet_url") @db.Text
  spreadsheetId   String   @map("spreadsheet_id") @db.VarChar(255)
  spreadsheetName String   @map("spreadsheet_name") @db.VarChar(255)
  sheetName       String   @map("sheet_name") @db.VarChar(255)
  syncEnabled     Boolean  @default(true) @map("sync_enabled")
  syncInterval    Int      @default(5) @map("sync_interval")
  lastSyncAt      DateTime? @map("last_sync_at")
  lastProcessedRow Int       @default(0) @map("last_processed_row")
  syncCursor       String?   @map("sync_cursor") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mappings        SpreadsheetColumnMapping[]
  histories       SpreadsheetImportHistory[]
  syncHistories   LeadSyncHistory[]
  syncLogs        SpreadsheetSyncLog[]
  syncErrors      SpreadsheetSyncError[]

  @@map("spreadsheet_connections")
}

model SpreadsheetColumnMapping {
  id           String   @id @default(uuid()) @db.Uuid
  connectionId String   @map("connection_id") @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  crmField     String   @map("crm_field") @db.VarChar(100)
  sheetColumn  String   @map("sheet_column") @db.VarChar(100)

  connection   SpreadsheetConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("spreadsheet_column_mappings")
}

model SpreadsheetImportHistory {
  id              String   @id @default(uuid()) @db.Uuid
  connectionId    String   @map("connection_id") @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  totalRows       Int      @map("total_rows")
  importedRows    Int      @map("imported_rows")
  duplicateRows   Int      @map("duplicate_rows")
  failedRows      Int      @map("failed_rows")
  spreadsheetName String?  @map("spreadsheet_name") @db.VarChar(255)
  sheetTabName    String?  @map("sheet_tab_name") @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at")

  connection    SpreadsheetConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("spreadsheet_import_histories")
}

enum SyncType {
  CREATED
  UPDATED
  DUPLICATE
}

model LeadSyncHistory {
  id                      String                @id @default(uuid()) @db.Uuid
  leadId                  String                @map("lead_id") @db.Uuid
  spreadsheetConnectionId String                @map("spreadsheet_connection_id") @db.Uuid
  syncType                SyncType              @map("sync_type")
  oldData                 Json?                 @map("old_data")
  newData                 Json?                 @map("new_data")
  syncedAt                DateTime              @default(now()) @map("synced_at")

  lead                    Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  connection              SpreadsheetConnection @relation(fields: [spreadsheetConnectionId], references: [id], onDelete: Cascade)

  @@map("lead_sync_histories")
}

enum SyncLogStatus {
  SUCCESS
  FAILED
  PARTIAL_SUCCESS
}

model SpreadsheetSyncLog {
  id                      String                @id @default(uuid()) @db.Uuid
  spreadsheetConnectionId String                @map("spreadsheet_connection_id") @db.Uuid
  startedAt               DateTime              @map("started_at")
  completedAt             DateTime              @map("completed_at")
  totalRows               Int                   @map("total_rows")
  insertedRows            Int                   @map("inserted_rows")
  updatedRows             Int                   @map("updated_rows")
  duplicateRows           Int                   @map("duplicate_rows")
  failedRows              Int                   @map("failed_rows")
  duration                Int                   @map("duration") // in milliseconds
  status                  SyncLogStatus
  errorMessage            String?               @map("error_message") @db.Text

  connection              SpreadsheetConnection @relation(fields: [spreadsheetConnectionId], references: [id], onDelete: Cascade)

  @@map("spreadsheet_sync_logs")
}

model SpreadsheetSyncError {
  id                      String                @id @default(uuid()) @db.Uuid
  spreadsheetConnectionId String                @map("spreadsheet_connection_id") @db.Uuid
  errorMessage            String                @map("error_message") @db.Text
  stackTrace              String?               @map("stack_trace") @db.Text
  rowData                 Json                  @map("row_data")
  spreadsheetId           String                @map("spreadsheet_id") @db.VarChar(255)
  createdAt               DateTime              @default(now()) @map("created_at")

  connection              SpreadsheetConnection @relation(fields: [spreadsheetConnectionId], references: [id], onDelete: Cascade)

  @@map("spreadsheet_sync_errors")
}

enum WorkflowTriggerType {
  NEW_LEAD
  STAGE_CHANGED
  LEAD_UPDATED
}

enum WorkflowActionType {
  SEND_EMAIL
  SEND_WHATSAPP
  ASSIGN_USER
  ADD_TAG
  CREATE_TASK
}

model Workflow {
  id          String            @id @default(uuid()) @db.Uuid
  clientId    String            @map("client_id") @db.Uuid
  name        String            @db.VarChar(255)
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  triggers    WorkflowTrigger[]
  actions     WorkflowAction[]

  @@map("workflows")
}

model WorkflowTrigger {
  id          String              @id @default(uuid()) @db.Uuid
  workflowId  String              @map("workflow_id") @db.Uuid
  type        WorkflowTriggerType
  config      Json?               // e.g. { stage: "WON" }
  createdAt   DateTime            @default(now()) @map("created_at")

  workflow    Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_triggers")
}

model WorkflowAction {
  id          String             @id @default(uuid()) @db.Uuid
  workflowId  String             @map("workflow_id") @db.Uuid
  type        WorkflowActionType
  config      Json               // e.g. { template: "welcome", to: "{{lead.email}}" }
  stepOrder   Int                @map("step_order")
  createdAt   DateTime           @default(now()) @map("created_at")

  workflow    Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_actions")
}

enum MessageSource {
  WHATSAPP
  EMAIL
  FACEBOOK
  INSTAGRAM
}

model Conversation {
  id            String        @id @default(uuid()) @db.Uuid
  clientId      String        @map("client_id") @db.Uuid
  leadId        String?       @map("lead_id") @db.Uuid
  source        MessageSource
  externalId    String        @map("external_id") @db.VarChar(255)
  contactName   String?       @map("contact_name") @db.VarChar(255)
  unreadCount   Int           @default(0) @map("unread_count")
  lastMessageAt DateTime      @default(now()) @map("last_message_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead          Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages      Message[]

  @@unique([clientId, source, externalId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  direction      String       @db.VarChar(10) // "INBOUND" or "OUTBOUND"
  content        String       @db.Text
  mediaUrl       String?      @map("media_url") @db.Text
  isRead         Boolean      @default(false) @map("is_read")
  sentAt         DateTime     @default(now()) @map("sent_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model LeadScore {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @unique @map("lead_id") @db.Uuid
  score     Int
  reason    String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_scores")
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

model Task {
  id            String     @id @default(uuid()) @db.Uuid
  clientId      String     @map("client_id") @db.Uuid
  leadId        String?    @map("lead_id") @db.Uuid
  title         String     @db.VarChar(255)
  description   String?    @db.Text
  dueDate       DateTime   @map("due_date")
  assignedTo    String?    @map("assigned_to") @db.Uuid
  status        TaskStatus @default(PENDING)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  client        Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead          Lead?      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedUser  User?      @relation(fields: [assignedTo], references: [id], onDelete: SetNull)

  @@map("tasks")
}

model Tag {
  id        String    @id @default(uuid()) @db.Uuid
  clientId  String    @map("client_id") @db.Uuid
  name      String    @db.VarChar(50)
  color     String    @default("#4F46E5") @db.VarChar(10)
  createdAt DateTime  @default(now()) @map("created_at")

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadTags  LeadTag[]

  @@unique([clientId, name])
  @@map("tags")
}

model LeadTag {
  leadId     String   @map("lead_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("lead_tags")
}

enum NotificationType {
  NEW_LEAD
  TASK_DUE
  WORKFLOW_FAILED
  SYNC_FAILED
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  clientId  String           @map("client_id") @db.Uuid
  userId    String?          @map("user_id") @db.Uuid // Target user, null for client-wide
  type      NotificationType
  title     String           @db.VarChar(255)
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
